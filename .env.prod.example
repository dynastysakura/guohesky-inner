APP_ENV=production
APP_PORT=13000
APP_KEY=                          # 运行 openssl rand -base64 48 生成，填入等号后面
TZ=Asia/Shanghai

PLUGIN_PACKAGE_PREFIX=@nocobase/plugin-,@nocobase/preset-,@nocobase/plugin-pro-,@my-project/plugin-

DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nocobase
DB_USER=nocobase
DB_PASSWORD=                      # 运行 openssl rand -base64 32 生成，填入等号后面

INIT_LANG=zh-CN
INIT_ROOT_EMAIL=admin@guohesky.com
INIT_ROOT_PASSWORD=               # 自己设一个密码，首次登录后可在界面修改
INIT_ROOT_USERNAME=nocobase
